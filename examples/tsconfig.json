{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": "../",
    "paths": {
      "@/*": ["src/*"],
      "@/types": ["src/types"],
      "@/exceptions": ["src/exceptions"],
      "@/providers/*": ["src/providers/*"],
      "@/utils/*": ["src/utils/*"]
    }
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}
